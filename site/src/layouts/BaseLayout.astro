---
// Self-hosted fonts (no render-blocking Google Fonts <link>). Variable
// weights cover everything we use; italic loaded only for the serif.
import '@fontsource-variable/crimson-pro';
import '@fontsource-variable/crimson-pro/wght-italic.css';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'PawPoller: publish your fiction everywhere',
  description = 'A story-first multi-platform publishing pipeline for furry fiction writers. Write once in Markdown, publish to Inkbunny, SoFurry, FurAffinity, AO3, Weasyl, SquidgeWorld and more.',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
// Absolute URL for social cards (og:image must be absolute).
// Branded logo card (1200x630) — generated by scripts/make_og_card.py.
const ogImage = new URL('og-card.png', Astro.site).href;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.site} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="PawPoller — copper quill logo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" type="image/png" href={`${base}/favicon.png`} />
    <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />
  </head>
  <body class="min-h-[100dvh] antialiased">
    <slot />
  </body>
</html>
