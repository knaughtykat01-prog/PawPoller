---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<header class="sticky top-0 z-20 border-b border-ink-800/70 bg-ink-900/85 backdrop-blur-md">
  <div class="container-prose flex h-16 items-center justify-between">
    <a href={`${base}/`} class="flex items-center gap-2 font-serif text-xl font-semibold text-ink-50">
      <span class="text-copper-400">◆</span>
      <span>PawPoller</span>
    </a>
    <nav class="hidden items-center gap-8 text-sm font-medium text-ink-200 sm:flex">
      <a href="#features" class="transition hover:text-copper-300">Features</a>
      <a href="#platforms" class="transition hover:text-copper-300">Platforms</a>
      <a href="#get" class="transition hover:text-copper-300">Get it</a>
      <a href="#faq" class="transition hover:text-copper-300">FAQ</a>
      <a href="https://github.com/knaughtykat01-prog/PawPoller" class="transition hover:text-copper-300">GitHub</a>
    </nav>
    <a href="#get" class="btn-primary !py-1.5 !px-3 text-sm">Download</a>
  </div>
</header>
