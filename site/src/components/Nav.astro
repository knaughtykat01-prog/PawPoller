---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const links = [
  { label: 'Posting', href: `${base}/posting` },
  { label: 'Analytics', href: `${base}/analytics` },
  { label: 'Platforms', href: `${base}/platforms` },
  { label: 'Security', href: `${base}/security` },
  { label: 'GitHub', href: 'https://github.com/knaughtykat01-prog/PawPoller' },
];
---
<header class="sticky top-0 z-20 border-b border-ink-800/70 bg-ink-900/85 backdrop-blur-md">
  <div class="container-prose flex h-16 items-center justify-between">
    <a href={`${base}/`} class="flex items-center gap-2.5 font-serif text-xl font-semibold text-ink-50">
      <img src={`${base}/logo-quill.png`} alt="" width="28" height="28" class="h-7 w-7" />
      <span>PawPoller</span>
    </a>
    <nav class="hidden items-center gap-7 text-sm font-medium text-ink-200 md:flex">
      {links.map((l) => (
        <a href={l.href} class="transition hover:text-copper-300">{l.label}</a>
      ))}
    </nav>
    <a href={`${base}/download`} class="btn-primary !py-1.5 !px-3 text-sm">Download</a>
  </div>
</header>
