---
import { FAQS } from '../lib/faqs';

export interface Props {
  title?: string;
  lead?: string;
  /** FAQ keys to show, in this order. Omit to show all. */
  show?: string[];
}

const {
  title = 'Short answers to honest questions.',
  lead = 'Free, local-first, and explicit about what it will and won\'t do on your behalf.',
  show,
} = Astro.props;

const faqs = show
  ? show.map((k) => FAQS.find((f) => f.key === k)).filter((f): f is NonNullable<typeof f> => Boolean(f))
  : FAQS;
---
<section id="faq" class="py-24">
  <div class="container-prose grid gap-12 md:grid-cols-[0.85fr_1.15fr] md:gap-16">
    <div class="md:sticky md:top-24 md:self-start">
      <h2 class="text-4xl text-ink-50 md:text-5xl">{title}</h2>
      <p class="mt-6 text-ink-300">
        {lead} Still unsure? Open a thread on
        <a class="link-accent" href="https://github.com/knaughtykat01-prog/PawPoller/discussions">GitHub Discussions</a>.
      </p>
    </div>

    <div class="divide-y divide-ink-800 rounded-lg border border-ink-800 bg-ink-900/50">
      {faqs.map((f) => (
        <details class="group p-6 open:bg-ink-900/80">
          <summary class="flex cursor-pointer items-center justify-between text-ink-100 transition hover:text-copper-300">
            <span class="font-serif text-lg">{f.q}</span>
            <span class="ml-4 text-copper-400 transition group-open:rotate-45">+</span>
          </summary>
          <p class="mt-4 text-sm leading-relaxed text-ink-300">{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
