---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();

const product = [
  { label: 'Posting', href: `${base}/posting` },
  { label: 'Analytics', href: `${base}/analytics` },
  { label: 'Artwork', href: `${base}/artwork` },
  { label: 'Social posts', href: `${base}/social` },
  { label: 'Platforms', href: `${base}/platforms` },
  { label: 'Security', href: `${base}/security` },
  { label: 'Download', href: `${base}/download` },
];

const docs = [
  { label: 'Setup guide', href: 'https://github.com/knaughtykat01-prog/PawPoller/blob/master/docs/SETUP.md' },
  { label: 'Technical reference', href: 'https://github.com/knaughtykat01-prog/PawPoller/blob/master/docs/documentation_guide.md' },
  { label: 'Changelog', href: 'https://github.com/knaughtykat01-prog/PawPoller/blob/master/CHANGELOG.md' },
  { label: 'Roadmap', href: 'https://github.com/knaughtykat01-prog/PawPoller/blob/master/docs/ROADMAP_PUBLIC.md' },
  { label: 'Releases', href: 'https://github.com/knaughtykat01-prog/PawPoller/releases' },
];

const community = [
  { label: 'GitHub', href: 'https://github.com/knaughtykat01-prog/PawPoller' },
  { label: 'Issues', href: 'https://github.com/knaughtykat01-prog/PawPoller/issues' },
  { label: 'Discussions', href: 'https://github.com/knaughtykat01-prog/PawPoller/discussions' },
  { label: 'Contribute', href: 'https://github.com/knaughtykat01-prog/PawPoller/blob/master/CONTRIBUTING.md' },
];
---
<footer class="border-t border-ink-800/60 bg-ink-950/60">
  <div class="container-prose grid gap-12 py-16 md:grid-cols-[2fr_1fr_1fr_1fr]">
    <div>
      <a href={`${base}/`} class="flex items-center gap-2.5 font-serif text-xl font-semibold text-ink-50">
        <img src={`${base}/logo-quill.png`} alt="" width="28" height="28" class="h-7 w-7" />
        PawPoller
      </a>
      <p class="mt-4 max-w-sm text-sm leading-relaxed text-ink-400">
        A story-first multi-platform publishing pipeline for furry fiction writers. Built by one author getting tired of reformatting the same novella six times.
      </p>
    </div>

    <div>
      <h4 class="font-serif text-sm uppercase tracking-wider text-copper-300">Product</h4>
      <ul class="mt-4 space-y-2 text-sm text-ink-300">
        {product.map((l) => (
          <li><a href={l.href} class="transition hover:text-copper-300">{l.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h4 class="font-serif text-sm uppercase tracking-wider text-copper-300">Docs</h4>
      <ul class="mt-4 space-y-2 text-sm text-ink-300">
        {docs.map((l) => (
          <li><a href={l.href} class="transition hover:text-copper-300">{l.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h4 class="font-serif text-sm uppercase tracking-wider text-copper-300">Community</h4>
      <ul class="mt-4 space-y-2 text-sm text-ink-300">
        {community.map((l) => (
          <li><a href={l.href} class="transition hover:text-copper-300">{l.label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="border-t border-ink-800/60">
    <div class="container-prose flex flex-col items-center justify-between gap-4 py-6 text-xs text-ink-500 md:flex-row">
      <div>© {year} PawPoller · MIT licensed</div>
      <div>Built by writers, for writers.</div>
    </div>
  </div>
</footer>
