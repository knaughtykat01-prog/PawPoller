---
// Home page "what it does" grid — four capability cards linking out to the
// dedicated pages, plus a tertiary row for the supporting pages.
import { Icon } from 'astro-icon/components';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const cards = [
  {
    icon: 'ph:paper-plane-tilt',
    title: 'Posting',
    body: 'Write one MASTER.md, regenerate every format, and publish to ten platforms with a confirmation matrix and drift detection.',
    href: `${base}/posting`,
  },
  {
    icon: 'ph:chart-line-up',
    title: 'Polling & analytics',
    body: 'Views, favourites, comments, reposts and more, pulled from all seventeen platforms and tracked over time in one dashboard.',
    href: `${base}/analytics`,
  },
  {
    icon: 'ph:image',
    title: 'Artwork',
    body: 'Track illustrations across Inkbunny, FurAffinity, Weasyl, DeviantArt, Itaku, Pixiv, e621 and Instagram — reach, favourites and comments.',
    href: `${base}/artwork`,
  },
  {
    icon: 'ph:chat-circle-text',
    title: 'Social posts',
    body: 'Measure your posts and tweets on Bluesky, X, Mastodon, Tumblr and Threads: likes, reposts, replies, quotes and views.',
    href: `${base}/social`,
  },
];

const more = [
  { icon: 'ph:squares-four', label: 'All 17 platforms', href: `${base}/platforms` },
  { icon: 'ph:lock-key', label: 'Security & your data', href: `${base}/security` },
  { icon: 'ph:download-simple', label: 'Download', href: `${base}/download` },
];
---
<section class="py-24">
  <div class="container-prose">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-4xl text-ink-50 md:text-5xl">One tool, four jobs.</h2>
      <p class="mt-6 text-ink-300">
        Publish your fiction, then measure everything you put out — stories, artwork and social posts — from a single dashboard.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2">
      {cards.map((c) => (
        <a href={c.href} class="card group flex flex-col p-8 transition hover:border-copper-500/60">
          <Icon name={c.icon} class="h-7 w-7 text-copper-400" />
          <h3 class="mt-4 text-2xl text-ink-50">{c.title}</h3>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-300">{c.body}</p>
          <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-copper-300 transition group-hover:text-copper-200">
            Explore
            <Icon name="ph:arrow-right" class="h-4 w-4 transition group-hover:translate-x-0.5" />
          </span>
        </a>
      ))}
    </div>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm">
      {more.map((m) => (
        <a href={m.href} class="inline-flex items-center gap-2 text-ink-300 transition hover:text-copper-300">
          <Icon name={m.icon} class="h-4 w-4" />
          {m.label}
        </a>
      ))}
    </div>
  </div>
</section>
