---
// Trust strip lifted out of the hero (the hero stays a single value-prop
// moment). Three numbers that frame the pitch before the problem statement.
// Platform counts derive from the platform matrix so they never drift.
import { POST_COUNT, POLL_COUNT } from '../lib/platforms';
const stats = [
  { value: String(POST_COUNT), label: 'Posting targets' },
  { value: String(POLL_COUNT), label: 'Polled platforms' },
  { value: '1',                label: 'Source of truth' },
];
---
<section class="border-y border-ink-800/60 bg-ink-950/40">
  <div class="container-prose grid grid-cols-3 divide-x divide-ink-800/60 py-10">
    {stats.map((s) => (
      <div class="px-4 text-center">
        <div class="font-serif text-3xl font-semibold text-copper-300 md:text-4xl">{s.value}</div>
        <div class="mt-1 text-xs uppercase tracking-wider text-ink-400">{s.label}</div>
      </div>
    ))}
  </div>
</section>
