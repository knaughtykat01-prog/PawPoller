---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import PageHero from '../components/PageHero.astro';
import Platforms from '../components/Platforms.astro';
import FAQ from '../components/FAQ.astro';
import CtaBand from '../components/CtaBand.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout
  title="Platforms — fifteen polled, nine posted | PawPoller"
  description="The full PawPoller platform matrix: which of the fifteen supported sites it posts to, which it polls for analytics, and what's currently undergoing testing."
>
  <Nav />
  <main>
    <PageHero
      eyebrow="Platforms"
      title="Fifteen polled."
      accent="Nine posted."
      lead="Track your whole footprint in one place — stories, artwork and social posts. Polling pulls views, favourites, notes, reposts and comments across fifteen platforms; posting supports nine of them. A few are still undergoing testing, marked below."
      primary={{ label: 'Download PawPoller', href: `${base}/download` }}
    />
    <div class="py-16">
      <Platforms />
    </div>
    <FAQ
      show={['why-nine', 'contribute']}
      title="About the platform list."
      lead="What PawPoller will and won't do per platform, and how to ask for more."
    />
    <CtaBand
      title="One dashboard for all fifteen."
      secondary={{ label: 'Polling & analytics', href: `${base}/analytics` }}
    />
  </main>
  <Footer />
</BaseLayout>
