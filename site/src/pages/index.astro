---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import Explore from '../components/Explore.astro';
import PlatformStrip from '../components/PlatformStrip.astro';
import CtaBand from '../components/CtaBand.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout>
  <Nav />
  <main>
    <Hero />
    <Stats />
    <Explore />

    <section class="border-t border-ink-800/60 bg-ink-950/30 py-24">
      <div class="container-prose">
        <div class="max-w-2xl">
          <h2 class="text-4xl text-ink-50 md:text-5xl">Fifteen platforms, one place.</h2>
          <p class="mt-6 text-ink-300">
            Post chaptered fiction to nine of them, track views, favourites, reposts and comments across all fifteen — stories, artwork and social posts alike.
          </p>
        </div>
        <div class="mt-10">
          <PlatformStrip href={`${base}/platforms`} linkLabel="See the full capability matrix" />
        </div>
      </div>
    </section>

    <CtaBand />
  </main>
  <Footer />
</BaseLayout>
