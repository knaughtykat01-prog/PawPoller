# PawPoller Server Environment Variables
# Copy to .env and fill in your credentials.
# Only uncomment the platforms you use.

# ── Inkbunny ──
# IB_USERNAME=
# IB_PASSWORD=

# ── FurAffinity ──
# FA_USERNAME=
# FA_COOKIE_A=
# FA_COOKIE_B=

# ── Weasyl ──
# WS_API_KEY=

# ── SoFurry ──
# SF_USERNAME=
# SF_PASSWORD=
# SF_DISPLAY_NAME=

# ── SquidgeWorld ──
# SQW_USERNAME=
# SQW_PASSWORD=
# SQW_TARGET_USER=

# ── Telegram Notifications ──
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_ENABLED=true
