# PawPoller Environment Variables
# Copy this file to .env and fill in your credentials.
# Only uncomment the platforms you use.
#
# These environment variables are only needed for headless/Docker deployments.
# Desktop mode configures everything through the Settings UI instead.
# Values here are seeded into settings.json on startup.

# ── Story archive location (optional; Docker) ──
# Host directory holding your story folders, bind-mounted into the container for
# the editor/publishing features. Defaults to ./story-archive next to
# docker-compose.yml. Leave unset if you don't use the story-publishing side.
# PAWPOLLER_ARCHIVE_DIR=./story-archive

# ── Inkbunny ──
# IB_USERNAME=
# IB_PASSWORD=

# ── FurAffinity ──
# FA_USERNAME=
# FA_COOKIE_A=
# FA_COOKIE_B=

# ── Weasyl ──
# WS_API_KEY=

# ── SoFurry ──
# SF_USERNAME=
# SF_PASSWORD=
# SF_DISPLAY_NAME=

# ── SquidgeWorld ──
# SQW_USERNAME=
# SQW_PASSWORD=
# SQW_TARGET_USER=

# ── AO3 (Archive of Our Own) ──
# AO3_USERNAME=
# AO3_PASSWORD=
# AO3_TARGET_USER=

# ── DeviantArt ──
# DA_COOKIE=
# DA_TARGET_USER=

# ── Wattpad ──
# WP_TARGET_USER=

# ── Itaku ──
# IK_TARGET_USER=

# ── Bluesky ──
# BSKY_IDENTIFIER=yourhandle.bsky.social
# BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── X / Twitter ──
# TW_AUTH_TOKEN=
# TW_CT0=
# TW_TARGET_USER=

# ── Mastodon ──
# Instance URL + a personal access token (Settings → Development → New
# application on your instance, scope: read).
# MAST_INSTANCE_URL=https://mastodon.social
# MAST_ACCESS_TOKEN=

# ── Tumblr ──
# OAuth Consumer Key (register an app at tumblr.com/oauth/apps) + a blog
# identifier (e.g. staff or staff.tumblr.com).
# TUM_API_KEY=
# TUM_BLOG=

# ── Pixiv ──
# A one-time refresh token (obtain via a Pixiv browser login, e.g. the gppt
# helper). PIX_USER_ID is optional — defaults to the authenticated account.
# PIX_REFRESH_TOKEN=
# PIX_USER_ID=

# ── Threads ──
# A long-lived user access token from a Meta app with threads_basic +
# threads_manage_insights scopes. THR_USER_ID optional (defaults to "me").
# THR_ACCESS_TOKEN=
# THR_USER_ID=

# ── Instagram ──
# A long-lived Instagram user access token from a Meta app with
# instagram_business_basic + instagram_business_manage_insights scopes,
# generated for a Business/Creator account. IG_USER_ID optional (defaults to "me").
# IG_ACCESS_TOKEN=
# IG_USER_ID=

# ── e621 ──
# Your e621 username + API key (Account → Manage API Access on e621 — this is
# the API KEY, not your account password). Poll-only: tracks your own uploads.
# E621_USERNAME=
# E621_API_KEY=

# ── Telegram Notifications ──
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_ENABLED=true

# ── Dashboard Authentication (Server/Docker) — IMPORTANT ──
# REQUIRED if the dashboard is reachable by anything other than localhost.
# Without a password, the dashboard AND its API are open to anyone who can
# reach the port — including endpoints that return every stored platform
# credential. Set this before exposing the instance (see PAWPOLLER_BIND).
# DASHBOARD_USER=admin
# DASHBOARD_PASSWORD=
#
# ── Network binding (Docker) ──
# Which host interface docker-compose publishes the dashboard on. Defaults to
# 127.0.0.1 (loopback only — safe). Set to 0.0.0.0 to expose on all interfaces,
# but ONLY behind a reverse proxy with TLS and with DASHBOARD_PASSWORD set.
# PAWPOLLER_BIND=127.0.0.1

# ── Credential vault key (Server/Docker; recommended) ──
# The credential vault is ALWAYS ON — stored secrets are encrypted in
# data/settings.vault.json. Without this setting the key falls back to
# data/.vault_key, next to the encrypted file — so on a server it's only as
# safe as the volume. For real at-rest protection, supply the key yourself
# (from your secrets manager) so it lives OFF the data volume — ideally before
# first run. Generate one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# PAWPOLLER_VAULT_KEY=
# ...or point at a mounted secret file instead of an env value:
# PAWPOLLER_VAULT_KEY_FILE=/run/secrets/pawpoller_vault_key

# ── Cloudflare Worker Proxy (optional) ──
# Routes DA/SF requests through Cloudflare to bypass datacenter IP blocks.
# Only needed for server/Docker deployments.
# CF_WORKER_URL=https://your-worker.workers.dev
# CF_WORKER_KEY=your-secret-key

# ── Debug ──
# Enable verbose CF proxy logging (very noisy, only for debugging)
# PAWPOLLER_DEBUG_PROXY=1
