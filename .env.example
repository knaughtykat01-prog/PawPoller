# PawPoller Server Environment Variables
# Copy to .env and fill in your credentials.
# Only uncomment the platforms you use.

# ── Inkbunny ──
# IB_USERNAME=
# IB_PASSWORD=

# ── FurAffinity ──
# FA_USERNAME=
# FA_COOKIE_A=
# FA_COOKIE_B=

# ── Weasyl ──
# WS_API_KEY=

# ── SoFurry ──
# SF_USERNAME=
# SF_PASSWORD=
# SF_DISPLAY_NAME=

# ── SquidgeWorld ──
# SQW_USERNAME=
# SQW_PASSWORD=
# SQW_TARGET_USER=

# ── AO3 (Archive of Our Own) ──
# AO3_USERNAME=
# AO3_PASSWORD=
# AO3_TARGET_USER=

# ── DeviantArt ──
# DA_COOKIE=
# DA_TARGET_USER=

# ── Wattpad ──
# WP_TARGET_USER=

# ── Itaku ──
# IK_TARGET_USER=

# ── Telegram Notifications ──
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_ENABLED=true

# ── Dashboard Authentication (Server/Docker only) ──
# Set a password to require HTTP Basic Auth on the dashboard.
# Without this, the dashboard is open to anyone who can reach the port.
# DASHBOARD_USER=admin
# DASHBOARD_PASSWORD=

# ── Cloudflare Worker Proxy (optional) ──
# Routes DA/SF requests through Cloudflare to bypass datacenter IP blocks.
# Only needed for server/Docker deployments.
# CF_WORKER_URL=https://your-worker.workers.dev
# CF_WORKER_KEY=your-secret-key
