# PawPoller Test Instance Environment
#
# This is the env file for the throwaway test container brought up by:
#   docker compose -f docker-compose.test.yml up -d --build
#
# The whole point of the test instance is to simulate a fresh-user
# install — so DON'T paste your real platform credentials here. Leave
# the platform vars blank so you exercise the setup wizard end-to-end
# from a clean slate.
#
# Copy this to .env.test before first run.

# ── Dashboard Authentication ──
# A throwaway password for the test instance. Doesn't have to be strong;
# this container should never be exposed to the internet.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=test

# ── Optional: pre-seed any platform creds you want available so you
# don't have to re-paste them every time you reset. Most testing should
# leave these blank to exercise the empty-state UI.
#
# IB_USERNAME=
# IB_PASSWORD=
